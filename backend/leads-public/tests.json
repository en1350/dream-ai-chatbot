{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing fields returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Missing slug and botId returns 400",
      "method": "POST",
      "path": "/",
      "body": {"email": "test@example.com"},
      "expectedStatus": 400
    },
    {
      "name": "Invalid email returns 400",
      "method": "POST",
      "path": "/",
      "body": {"slug": "test", "email": "not-an-email"},
      "expectedStatus": 400
    },
    {
      "name": "Unknown slug returns 404",
      "method": "POST",
      "path": "/",
      "body": {"slug": "unknown-slug-xyz", "email": "test@example.com"},
      "expectedStatus": 404
    }
  ]
}